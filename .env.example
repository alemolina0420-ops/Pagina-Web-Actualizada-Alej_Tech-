# ──────────────────────────────────────────────
# TecnoStore — Variables de Entorno (TEMPLATE)
# ──────────────────────────────────────────────
# INSTRUCCIONES:
# 1. Copia este archivo como .env
# 2. Reemplaza los valores de ejemplo con tus datos reales
# 3. NO subas el archivo .env a GitHub (ya está en .gitignore)

# Número de WhatsApp del negocio (formato internacional sin +)
# Ejemplo: 584121234567
VITE_WHATSAPP_NUMBER=584123979581

# URL canónica del sitio (para Open Graph y SEO)
# Desarrollo: http://localhost:5173
# Producción: https://tu-dominio.com
VITE_SITE_URL=https://tecnostore.vercel.app

# ──────────────────────────────────────────────
# NOTAS DE SEGURIDAD:
# ──────────────────────────────────────────────
# - Variables con prefijo VITE_ son PÚBLICAS (accesibles en el cliente)
# - NO pongas API keys secretas aquí
# - Para secretos del servidor, usa variables sin prefijo VITE_
#   (pero este proyecto es frontend-only, no aplica)
